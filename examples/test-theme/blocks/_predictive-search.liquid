{% doc %}
  Outputs a search button and a full-screen `<dialog>` with a live predictive search field.
  Results are fetched as you type using the Shopify Predictive Search API and rendered inside
  the `predictive-search-results` section via AJAX. Submitting the form navigates to the full search page.
  Requires the section `predictive-search-results.liquid`.

  @example
  {% content_for 'block', type: '_predictive-search', id: 'search' %}
{% enddoc %}

<a
  href="{{ routes.search_url }}"
  class="button ghost"
  onclick="event.preventDefault(); event.stopPropagation(); document.getElementById('predictive_search')?.getAttribute('open') ? document.getElementById('predictive_search')?.close() : document.getElementById('predictive_search')?.showModal()"
>
  Search
</a>

<dialog
  scroll-lock
  id="predictive_search"
  closedby="any"
  class="top-4 right-4 bottom-auto left-4 max-h-(--vvh) w-[calc(100%-2rem)] max-w-none overflow-auto overscroll-contain"
  style="view-transition-name: predictive-search"
>
  <article class="relative z-2 w-full justify-center px-4">
    <div
      x-data="{ q: '' }"
      data-loading-states
      data-loading-target="#predictive_search_input"
      data-loading-aria-busy
      class="mx-auto grid w-full max-w-3xl grid-rows-[auto_1fr] md:pb-40"
    >
      <div class="sticky top-0 mb-6 flex items-center gap-2 pt-5 md:pt-30">
        {% comment %} Used as input to the (hidden) predictive search below {% endcomment %}
        <form
          class="contents"
          @submit="document.getElementById('predictive_search')?.close()"
          action="{{ routes.search_url }}"
        >
          <input type="hidden" name="type" value="product,page">
          <input type="hidden" name="options[unavailable_products]" value="hide">
          <input type="hidden" name="options[prefix]" value="last">

          <label class="w-full">
            <span data-prefix>
              {% render 'icon-magnifier' %}
            </span>

            <input
              id="predictive_search_input"
              type="text"
              placeholder="Search products and pages"
              autofocus
              name="q"
              x-model="q"
              x-ref="input"
              @input.debounced="$refs.predictiveSearchForm.requestSubmit()"
            >

            <button type="submit" data-suffix class="button">Search</button>
          </label>
        </form>

        <form data-suffix method="dialog">
          <button class="button ghost">Close {% render 'icon-cross' %}</button>
        </form>
      </div>

      <form
        class="sr-only"
        x-ref="predictiveSearchForm"
        action="{{ routes.predictive_search_url }}"
        hx-get="{{ routes.predictive_search_url }}"
        hx-select="#predictive-search-results"
        hx-target="#predictive-search-results"
        hx-swap="outerHTML"
        hx-sync="this:replace"
      >
        <input type="search" name="q" x-model="q">
        <input type="hidden" name="section_id" value="predictive-search-results">
        <input type="hidden" name="type" value="product,page">
        <input type="hidden" name="options[unavailable_products]" value="hide">
        <input type="hidden" name="options[prefix]" value="last">
      </form>

      <div x-show="q !== ''" x-ref="predictiveSearchResults">
        <output id="predictive-search-results" class="bg-white pb-4"> </output>
      </div>
    </div>
  </article>
</dialog>

{% stylesheet %}
  dialog#predictive_search:not(:has(output:first-child)) {
    touch-action: none;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Predictive search",
  "presets": [
    {
      "name": "Predictive search"
    }
  ]
}
{% endschema %}
