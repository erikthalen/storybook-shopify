{
  "name": "shopify-starter",
  "version": "1.0.0",
  "private": true,
  "author": {
    "name": "Erik Thalén",
    "url": "https://github.com/erikthalen"
  },
  "repository": "github:erikthalen/shopify-starter",
  "type": "module",
  "scripts": {
    "dev": "pnpm run shopify:dev & pnpm run vite:dev",
    "vite:dev": "vite",
    "vite:build": "vite build",
    "shopify:dev": "shopify theme dev -e development --open",
    "prettier": "prettier . --write",
    "storybook": "storybook dev -p 6007",
    "build-storybook": "storybook build"
  },
  "devDependencies": {
    "@shopify/prettier-plugin-liquid": "^1.5.2",
    "@storybook/builder-vite": "^10.0.0",
    "@tailwindcss/vite": "4.2.2",
    "@types/alpinejs": "^3.13.11",
    "@types/alpinejs__intersect": "^3.13.4",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "vite": "^8.0.7",
    "vite-plugin-shopify": "4.1.2",
    "storybook": "^10.0.0"
  },
  "dependencies": {
    "@alpinejs/intersect": "^3.14.9",
    "@swup/a11y-plugin": "^5.0.0",
    "@swup/debug-plugin": "^4.1.0",
    "@swup/preload-plugin": "^3.2.11",
    "alpinejs": "3.15.11",
    "embla-carousel": "^8.6.0",
    "htmx-ext-preload": "^2.1.2",
    "htmx.org": "^2.0.8",
    "idiomorph": "^0.7.4",
    "storybook-shopify": "workspace:*",
    "swup": "4.8.3",
    "tailwindcss": "4.2.2"
  },
  "prettier": {
    "trailingComma": "es5",
    "tabWidth": 2,
    "semi": false,
    "singleQuote": false,
    "arrowParens": "avoid",
    "plugins": [
      "@shopify/prettier-plugin-liquid",
      "prettier-plugin-tailwindcss"
    ]
  }
}
