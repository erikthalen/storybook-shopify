{% doc %}
  Outputs a standard previous/next and numbered pagination nav.
  Only renders when there is more than one page. The current page is underlined.
  Use this as a fallback or alternative to the `infinite-scroll` snippet.

  @param {object} paginate - Shopify `paginate` object.

  @example
  {% paginate collection.products by 12 %}
    <ol>
      {% for product in collection.products %}
        <li>{{ product.title }}</li>
      {% endfor %}
    </ol>

    {% render 'pagination', paginate: paginate %}
  {% endpaginate %}
{% enddoc %}

{%- if paginate.pages > 1 -%}
  <nav role="navigation" aria-label="Pagination" class="mt-20 flex justify-center" x-data>
    <ol class="flex gap-4">
      {%- if paginate.previous -%}
        <li>
          <a
            class="border-b border-dotted"
            @mousedown="window.forcePageRefresh = true"
            href="{{ paginate.previous.url }}"
          >
            Previous <span class="sr-only">page</span>
          </a>
        </li>
      {%- else -%}
        <li class="text-neutral-500">Previous <span class="sr-only">page</span></li>
      {%- endif -%}

      {%- for part in paginate.parts -%}
        {%- if part.is_link -%}
          <li>
            <a @mousedown="window.forcePageRefresh = true" href="{{ part.url }}">
              <span class="sr-only">page</span> {{ part.title }}
            </a>
          </li>
        {%- else -%}
          {%- if part.title == paginate.current_page -%}
            <li class="underline" aria-current="page"><span class="sr-only">page</span> {{ part.title }}</li>
          {%- else -%}
            <li><span class="sr-only">page</span> {{ part.title }}</li>
          {%- endif -%}
        {%- endif -%}
      {%- endfor -%}

      {%- if paginate.next -%}
        <li>
          <a
            class="border-b border-dotted"
            @mousedown="window.forcePageRefresh = true"
            href="{{ paginate.next.url }}"
          >
            Next <span class="sr-only">page</span>
          </a>
        </li>
      {%- else -%}
        <li class="text-neutral-500">Next <span class="sr-only">page</span></li>
      {%- endif -%}
    </ol>
  </nav>
{%- endif -%}
