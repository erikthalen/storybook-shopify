{% doc %}
  Place this inside a paginated list container. When the snippet scrolls into view,
  the next page is fetched automatically and its items are appended to the list.
  The container must have `id="paginated_items"` for the swap to work.
  The intersection/fetch logic is handled via htmx's `intersect` trigger.

  @param {object} paginate - Shopify `paginate` object.

  @example
  {% paginate collection.products by 12 %}
    <ol id="paginated_items">
      {% for product in collection.products %}
        <li>{{ product.title }}</li>
      {% endfor %}

      {% render 'infinite-scroll', paginate: paginate %}
    </ol>
  {% endpaginate %}
{% enddoc %}

<div id="pagination" class="contents">
  {%- if paginate.next -%}
    {% comment %} Loading skeletons {% endcomment %}
    {% for i in (1..3) %}
      {% if forloop.first %}
        <div
          hx-get="{{ paginate.next.url }}"
          hx-trigger="intersect once"
          hx-target="#paginated_items"
          hx-select="#paginated_items > li"
          hx-swap="beforeend show:none"
          hx-select-oob="#pagination:outerHTML"
          data-loading-states
        >
          {% render 'product-card-skeleton' %}
        </div>
      {% else %}
        {% render 'product-card-skeleton' %}
      {% endif %}
    {% endfor %}

    <a class="sr-only" href="{{ paginate.next.url }}">Next page</a>
  {%- endif -%}
</div>
