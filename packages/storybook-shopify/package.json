{
  "name": "storybook-shopify",
  "version": "0.1.0",
  "description": "Storybook framework for Shopify/Liquid templates",
  "keywords": [
    "storybook",
    "shopify",
    "liquid"
  ],
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./preset": {
      "types": "./dist/preset.d.ts",
      "import": "./dist/preset.js"
    },
    "./renderer-preset": {
      "types": "./dist/renderer-preset.d.ts",
      "import": "./dist/renderer-preset.js"
    },
    "./entry-preview": {
      "types": "./dist/entry-preview.d.ts",
      "import": "./dist/entry-preview.js"
    }
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch"
  },
  "dependencies": {
    "liquidjs": "^10.21.0"
  },
  "peerDependencies": {
    "@storybook/builder-vite": "^10.0.0",
    "storybook": "^10.0.0"
  },
  "devDependencies": {
    "@storybook/builder-vite": "^10.0.0",
    "@types/node": "^25.6.0",
    "storybook": "^10.0.0",
    "typescript": "^5.0.0",
    "vite": "^8.0.0"
  }
}
