{
  "name": "storybook-shopify-monorepo",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "build": "pnpm --filter './packages/**' build",
    "dev": "pnpm --filter './packages/**' dev",
    "test": "pnpm --filter './packages/**' test",
    "storybook": "pnpm --filter './examples/**' storybook",
    "build-storybook": "pnpm --filter './examples/**' build-storybook",
    "docs:dev": "pnpm --filter @storybook-shopify/docs dev",
    "docs:build": "pnpm --filter @storybook-shopify/docs build"
  }
}
